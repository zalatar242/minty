# Minty — environment variable reference
#
# Copy this file to .env (or just set the variables inline) when running
# the relevant importer. None of these are required by the main server
# (`npm run crm`); they're only used by the optional data source importers.
#
# Do NOT commit a real .env file. It's already in .gitignore.

# -----------------------------------------------------------------------------
# LinkedIn importer — `npm run linkedin`
# -----------------------------------------------------------------------------
# Path to the extracted LinkedIn data export (ZIP from LinkedIn → Settings →
# Data Privacy → Get a copy of your data). Request Connections + Messages.
# LINKEDIN_EXPORT_DIR=/path/to/linkedin-export

# -----------------------------------------------------------------------------
# Telegram importer — `npm run telegram`
# -----------------------------------------------------------------------------
# Path to result.json from Telegram Desktop → Settings → Advanced →
# Export Telegram Data → Personal chats + Contacts (format: JSON).
# TELEGRAM_EXPORT_FILE=/path/to/result.json

# -----------------------------------------------------------------------------
# Email (IMAP) importer — `npm run email`
# -----------------------------------------------------------------------------
# Requires: npm install imap mailparser
# Gmail: generate an App Password at myaccount.google.com/apppasswords
# EMAIL_HOST=imap.gmail.com
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=your_app_password_here
# EMAIL_PORT=993          # optional, default 993
# EMAIL_TLS=true          # optional, default true

# -----------------------------------------------------------------------------
# Google Contacts importer — `npm run google-contacts`
# -----------------------------------------------------------------------------
# Path to CSV exported from contacts.google.com (Google CSV format).
# GOOGLE_CONTACTS_CSV=/path/to/contacts.csv

# -----------------------------------------------------------------------------
# SMS importer — `npm run sms`
# -----------------------------------------------------------------------------
# Path to XML export from the SMS Backup & Restore Android app.
# SMS_EXPORT_FILE=/path/to/sms-20240101010101.xml

# -----------------------------------------------------------------------------
# Apollo enrichment (OPTIONAL, only source that makes external API calls)
# -----------------------------------------------------------------------------
# Enriches contacts with job title, company, location via Apollo.io.
# Leave unset to skip. This is the only importer that sends data off-device.
# APOLLO_API_KEY=

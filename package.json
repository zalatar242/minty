    "digest": "node crm/digest.js",
    "index": "node crm/index.js",
    "test": "node --test tests/unit/schema.test.js tests/unit/utils.test.js tests/unit/scoring.test.js tests/unit/contact-index.test.js tests/unit/sync.test.js tests/unit/sync-utils.test.js tests/unit/health-ring.test.js tests/unit/goals.test.js tests/unit/reconnect.test.js tests/unit/calendar.test.js tests/unit/network-query.test.js tests/unit/staleness.test.js"

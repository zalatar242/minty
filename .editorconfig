# https://editorconfig.org — keeps whitespace consistent across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false  # markdown line-break syntax uses trailing spaces

[*.{json,yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
